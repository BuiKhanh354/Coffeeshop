@{
    ViewData["Title"] = "Đặt hàng thành công";
}

<!-- Order Success Page -->
<section class="pt-24 pb-16 min-h-screen bg-gradient-to-b from-green-50 to-white dark:from-gray-900 dark:to-gray-800 flex items-center">
    <div class="max-w-2xl mx-auto px-6 text-center">
        <!-- Success Icon -->
        <div class="w-24 h-24 mx-auto mb-8 rounded-full bg-green-100 dark:bg-green-900/30 flex items-center justify-center animate-bounce">
            <svg class="w-12 h-12 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
        </div>

        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-white mb-4">
            Đặt hàng <span class="text-green-600 dark:text-green-400">thành công!</span>
        </h1>

        <p class="text-xl text-gray-600 dark:text-gray-400 mb-4">
            Cảm ơn bạn đã đặt hàng tại Coffee Shop
        </p>

        <!-- Order Details Card -->
        <div class="bg-white dark:bg-gray-800 rounded-2xl p-6 shadow-lg border border-gray-100 dark:border-gray-700 mb-8">
            @if (ViewBag.OrderCode != null)
            {
                <div class="flex justify-between items-center py-3 border-b border-gray-200 dark:border-gray-700">
                    <span class="text-gray-600 dark:text-gray-400">Mã đơn hàng:</span>
                    <span class="font-bold text-lg text-amber-600 dark:text-amber-400">@ViewBag.OrderCode</span>
                </div>
            }
            @if (ViewBag.TotalAmount != null)
            {
                <div class="flex justify-between items-center py-3 border-b border-gray-200 dark:border-gray-700">
                    <span class="text-gray-600 dark:text-gray-400">Tổng tiền:</span>
                    <span class="font-bold text-lg text-gray-900 dark:text-white">@ViewBag.TotalAmount đ</span>
                </div>
            }
            @if (ViewBag.PaymentMethod != null)
            {
                <div class="flex justify-between items-center py-3">
                    <span class="text-gray-600 dark:text-gray-400">Phương thức:</span>
                    <span class="font-bold text-gray-900 dark:text-white">
                        @switch (ViewBag.PaymentMethod)
                        {
                            case "COD":
                                <span class="inline-flex items-center gap-1">💵 Thanh toán khi nhận hàng</span>
                                break;
                            case "BankTransfer":
                                <span class="inline-flex items-center gap-1">🏦 Chuyển khoản ngân hàng</span>
                                break;
                            case "QRCode":
                                <span class="inline-flex items-center gap-1">📱 Thanh toán QR Code</span>
                                break;
                            default:
                                @ViewBag.PaymentMethod
                                break;
                        }
                    </span>
                </div>
            }
        </div>

        <p class="text-gray-500 dark:text-gray-400 mb-10">
            Chúng tôi sẽ liên hệ với bạn trong thời gian sớm nhất để xác nhận đơn hàng.
        </p>

        <div class="flex flex-col sm:flex-row justify-center gap-4">
            <a href="/Products" class="px-8 py-4 rounded-xl bg-gradient-to-r from-amber-600 to-orange-600 text-white font-bold hover:from-amber-700 hover:to-orange-700 transition-all duration-300 shadow-lg shadow-amber-500/25">
                Tiếp tục mua sắm
            </a>
            <a href="/" class="px-8 py-4 rounded-xl border-2 border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 font-bold hover:border-amber-600 hover:text-amber-600 dark:hover:border-amber-400 dark:hover:text-amber-400 transition-all duration-300">
                Về trang chủ
            </a>
        </div>

        <!-- Order Info Cards -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mt-12">
            <div class="p-6 rounded-xl bg-white dark:bg-gray-800 shadow-lg border border-gray-100 dark:border-gray-700">
                <div class="w-12 h-12 mx-auto mb-4 rounded-lg bg-blue-100 dark:bg-blue-900/30 flex items-center justify-center">
                    <svg class="w-6 h-6 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                    </svg>
                </div>
                <h3 class="font-bold text-gray-900 dark:text-white mb-2">Email xác nhận</h3>
                <p class="text-sm text-gray-500 dark:text-gray-400">Bạn sẽ nhận được email xác nhận đơn hàng</p>
            </div>

            <div class="p-6 rounded-xl bg-white dark:bg-gray-800 shadow-lg border border-gray-100 dark:border-gray-700">
                <div class="w-12 h-12 mx-auto mb-4 rounded-lg bg-amber-100 dark:bg-amber-900/30 flex items-center justify-center">
                    <svg class="w-6 h-6 text-amber-600 dark:text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                </div>
                <h3 class="font-bold text-gray-900 dark:text-white mb-2">Thời gian giao hàng</h3>
                <p class="text-sm text-gray-500 dark:text-gray-400">Dự kiến 2-3 ngày làm việc</p>
            </div>

            <div class="p-6 rounded-xl bg-white dark:bg-gray-800 shadow-lg border border-gray-100 dark:border-gray-700">
                <div class="w-12 h-12 mx-auto mb-4 rounded-lg bg-purple-100 dark:bg-purple-900/30 flex items-center justify-center">
                    <svg class="w-6 h-6 text-purple-600 dark:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                    </svg>
                </div>
                <h3 class="font-bold text-gray-900 dark:text-white mb-2">Hỗ trợ</h3>
                <p class="text-sm text-gray-500 dark:text-gray-400">Hotline: 0123 456 789</p>
            </div>
        </div>
    </div>
</section>
