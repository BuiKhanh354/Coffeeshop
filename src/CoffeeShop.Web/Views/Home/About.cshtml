            </div>
            <div class="p-6 group">
                <div class="text-5xl md:text-6xl font-bold mb-2 group-hover:scale-110 transition-transform">100+</div>
                <div class="text-amber-100 text-lg">Món đồ uống</div>
            </div>
            <div class="p-6 group">
                <div class="text-5xl md:text-6xl font-bold mb-2 group-hover:scale-110 transition-transform">4.9</div>
                <div class="text-amber-100 text-lg">Đánh giá trung bình</div>
            </div>
        </div>
    </div>
</section>

<!-- Testimonials Section - "Những Lời Thương" -->
<section class="py-24 bg-gradient-to-b from-gray-50 to-white dark:from-gray-800 dark:to-gray-900">
    <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-16">
            <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-pink-100 dark:bg-pink-900/30 text-pink-700 dark:text-pink-400 text-sm font-semibold mb-6">
                <span>💬</span> NHỮNG LỜI THƯƠNG
            </div>
            <h2 class="text-3xl md:text-5xl font-bold text-gray-900 dark:text-white mb-4">
                Khách Hàng <span class="text-pink-600 dark:text-pink-400">Nói Gì</span> Về Chúng Tôi
            </h2>
            <p class="text-gray-600 dark:text-gray-400 text-lg max-w-2xl mx-auto">
