<!-- CTA Section -->
<section class="py-24 bg-gradient-to-r from-amber-600 via-orange-600 to-amber-700 dark:from-amber-800 dark:via-orange-800 dark:to-amber-900">
    <div class="max-w-4xl mx-auto px-6 text-center">
        <h2 class="text-4xl md:text-5xl font-bold text-white mb-6">
            Sẵn sàng thưởng thức?
        </h2>
        <p class="text-xl text-amber-100 mb-10">
            Ghé thăm chúng tôi hoặc đặt hàng online ngay hôm nay
        </p>
        <div class="flex flex-col sm:flex-row justify-center gap-4">
            <a href="#" class="px-8 py-4 rounded-2xl bg-white text-amber-700 font-bold text-lg hover:bg-gray-100 transform hover:-translate-y-1 transition-all duration-300 shadow-xl">
                Đặt hàng ngay
            </a>
            <a href="#contact" class="px-8 py-4 rounded-2xl border-2 border-white text-white font-bold text-lg hover:bg-white hover:text-amber-700 transform hover:-translate-y-1 transition-all duration-300">
                Xem địa chỉ
            </a>
        </div>
    </div>
</section>

