            <div class="p-8 rounded-3xl bg-gradient-to-br from-pink-50 to-pink-100 dark:from-pink-900/20 dark:to-pink-800/20 border border-pink-200 dark:border-pink-800/30 hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1">
                <div class="flex items-center gap-1 mb-4">
                    <span class="text-amber-400 text-xl">★</span>
                    <span class="text-amber-400 text-xl">★</span>
                    <span class="text-amber-400 text-xl">★</span>
                    <span class="text-amber-400 text-xl">★</span>
                    <span class="text-amber-400 text-xl">★</span>
                </div>
