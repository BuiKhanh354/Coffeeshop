<!-- Coffee Story Section -->
<section class="relative py-24 overflow-hidden">
    <div class="absolute inset-0">
        <img src="/images/coffee-story.png" alt="Coffee plantation" class="w-full h-full object-cover"/>
        <div class="absolute inset-0 bg-gradient-to-r from-slate-900/95 via-slate-900/80 to-slate-900/60"></div>
    </div>
    
    <div class="relative z-10 max-w-7xl mx-auto px-6">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
            <div class="text-white space-y-6">
                <div class="flex items-center gap-3">
                    <span class="text-4xl">☕</span>
                    <div class="h-px flex-1 bg-gradient-to-r from-amber-400 to-transparent"></div>
                </div>
                
                <h2 class="text-4xl md:text-5xl font-bold leading-tight">
                    Nguyên Bản Từ Giá Trị
                    <span class="block text-amber-400">Hạt Cà Phê Chất Lượng</span>
                </h2>
                
                <p class="text-xl text-gray-300 leading-relaxed">
                    Mọi ly cà phê tại Coffee Shop đều bắt đầu từ một hạt cà phê nguyên bản. 
                    Chúng tôi tuyển chọn kỹ lưỡng từ những vùng trồng nổi tiếng của Việt Nam 
                    như Đắk Lắk, Lâm Đồng, Sơn La.
                </p>
                
                <ul class="space-y-4 text-gray-300">
                    <li class="flex items-center gap-3">
                        <span class="w-2 h-2 rounded-full bg-amber-400"></span>
                        <span>100% Arabica & Robusta chọn lọc</span>
                    </li>
                    <li class="flex items-center gap-3">
                        <span class="w-2 h-2 rounded-full bg-amber-400"></span>
                        <span>Rang xay tươi mỗi ngày</span>
                    </li>
                    <li class="flex items-center gap-3">
                        <span class="w-2 h-2 rounded-full bg-amber-400"></span>
                        <span>Quy trình kiểm soát chất lượng nghiêm ngặt</span>
                    </li>
                </ul>
                
                <a href="/Home/About" class="inline-flex items-center gap-2 text-amber-400 font-semibold hover:text-amber-300 transition-colors group">
                    <span>Tìm hiểu thêm</span>
                    <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                    </svg>
                </a>
            </div>
            
            <div class="hidden lg:block">
                <!-- Visual space for the background image -->
            </div>
        </div>
    </div>
</section>
