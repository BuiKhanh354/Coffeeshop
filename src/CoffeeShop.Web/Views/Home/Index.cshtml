@{
    ViewData["Title"] = "Trang Chủ";
}

<!-- Hero Section -->
<section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-gradient-to-br from-amber-50 via-orange-50 to-yellow-50 dark:from-gray-900 dark:via-gray-800 dark:to-gray-900">
    <!-- Animated Background Elements -->
    <div class="absolute inset-0 overflow-hidden">
        <div class="absolute -top-40 -right-40 w-80 h-80 bg-amber-200/30 dark:bg-amber-900/20 rounded-full blur-3xl animate-pulse"></div>
        <div class="absolute -bottom-40 -left-40 w-96 h-96 bg-orange-200/30 dark:bg-orange-900/20 rounded-full blur-3xl animate-pulse" style="animation-delay: 1s;"></div>
        <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-64 h-64 bg-yellow-200/20 dark:bg-yellow-900/10 rounded-full blur-2xl animate-pulse" style="animation-delay: 2s;"></div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 py-20 text-center">
        <!-- Coffee Icon Animation -->
        <div class="mb-8 animate-bounce">
            <span class="text-8xl md:text-9xl filter drop-shadow-2xl">☕</span>
        </div>

        <h1 class="text-5xl md:text-7xl font-extrabold mb-6 bg-gradient-to-r from-amber-600 via-orange-600 to-amber-700 dark:from-amber-400 dark:via-orange-400 dark:to-yellow-400 bg-clip-text text-transparent">
            Coffee Shop
        </h1>

        <p class="text-xl md:text-2xl text-gray-700 dark:text-gray-300 mb-4 font-medium">
            Thưởng thức hương vị cà phê đích thực
        </p>

        <p class="text-lg text-gray-500 dark:text-gray-400 mb-12 max-w-2xl mx-auto">
            Cà phê rang xay nguyên chất • Không gian ấm cúng • Phục vụ tận tâm
        </p>

        <div class="flex flex-col sm:flex-row justify-center gap-4 sm:gap-6">
            <a href="#menu" 
               class="group relative px-8 py-4 rounded-2xl bg-gradient-to-r from-amber-600 to-orange-600 text-white font-bold text-lg shadow-xl shadow-amber-500/25 hover:shadow-amber-500/40 transform hover:-translate-y-1 transition-all duration-300 overflow-hidden">
                <span class="relative z-10 flex items-center justify-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                    </svg>
                    Xem Menu
                </span>
                <div class="absolute inset-0 bg-gradient-to-r from-orange-600 to-amber-600 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            </a>

            <a href="#contact" 
               class="group px-8 py-4 rounded-2xl border-2 border-amber-600 dark:border-amber-500 text-amber-700 dark:text-amber-400 font-bold text-lg backdrop-blur-sm hover:bg-amber-600 hover:text-white dark:hover:bg-amber-500 dark:hover:text-gray-900 transform hover:-translate-y-1 transition-all duration-300">
                <span class="flex items-center justify-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                    </svg>
                    Liên Hệ
                </span>
            </a>
        </div>

        <!-- Scroll Indicator -->
        <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce">
            <svg class="w-6 h-6 text-amber-600 dark:text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
            </svg>
        </div>
    </div>
</section>

<!-- Features Section -->
<section class="py-24 bg-white dark:bg-gray-900 transition-colors duration-300">
    <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-16">
            <h2 class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-white mb-4">
                Tại sao chọn <span class="text-amber-600 dark:text-amber-400">chúng tôi?</span>
            </h2>
            <p class="text-gray-600 dark:text-gray-400 text-lg max-w-2xl mx-auto">
                Cam kết mang đến trải nghiệm cà phê tuyệt vời nhất cho bạn
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <!-- Feature 1 -->
            <div class="group p-8 rounded-3xl bg-gradient-to-br from-amber-50 to-orange-50 dark:from-gray-800 dark:to-gray-800 border border-amber-100 dark:border-gray-700 hover:shadow-2xl hover:shadow-amber-500/10 transform hover:-translate-y-2 transition-all duration-300">
                <div class="w-16 h-16 mb-6 rounded-2xl bg-gradient-to-br from-amber-500 to-orange-500 flex items-center justify-center shadow-lg shadow-amber-500/30 group-hover:scale-110 transition-transform duration-300">
                    <span class="text-3xl">🌿</span>
                </div>
                <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-3">
                    Nguyên Liệu Tươi
                </h3>
                <p class="text-gray-600 dark:text-gray-400">
                    Hạt cà phê được chọn lọc kỹ càng từ những vùng trồng nổi tiếng, rang xay mỗi ngày
                </p>
            </div>

            <!-- Feature 2 -->
            <div class="group p-8 rounded-3xl bg-gradient-to-br from-orange-50 to-yellow-50 dark:from-gray-800 dark:to-gray-800 border border-orange-100 dark:border-gray-700 hover:shadow-2xl hover:shadow-orange-500/10 transform hover:-translate-y-2 transition-all duration-300">
                <div class="w-16 h-16 mb-6 rounded-2xl bg-gradient-to-br from-orange-500 to-yellow-500 flex items-center justify-center shadow-lg shadow-orange-500/30 group-hover:scale-110 transition-transform duration-300">
                    <span class="text-3xl">👨‍🍳</span>
                </div>
                <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-3">
                    Barista Chuyên Nghiệp
                </h3>
                <p class="text-gray-600 dark:text-gray-400">
                    Đội ngũ barista được đào tạo bài bản, tận tâm với từng ly cà phê
                </p>
            </div>

            <!-- Feature 3 -->
            <div class="group p-8 rounded-3xl bg-gradient-to-br from-yellow-50 to-amber-50 dark:from-gray-800 dark:to-gray-800 border border-yellow-100 dark:border-gray-700 hover:shadow-2xl hover:shadow-yellow-500/10 transform hover:-translate-y-2 transition-all duration-300">
                <div class="w-16 h-16 mb-6 rounded-2xl bg-gradient-to-br from-yellow-500 to-amber-500 flex items-center justify-center shadow-lg shadow-yellow-500/30 group-hover:scale-110 transition-transform duration-300">
                    <span class="text-3xl">🏠</span>
                </div>
                <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-3">
                    Không Gian Thoải Mái
                </h3>
                <p class="text-gray-600 dark:text-gray-400">
                    Thiết kế ấm cúng, hiện đại, lý tưởng để làm việc hoặc thư giãn
                </p>
            </div>
        </div>
    </div>
</section>

<!-- Menu Showcase Section -->
<section id="menu" class="py-24 bg-gradient-to-b from-gray-50 to-white dark:from-gray-800 dark:to-gray-900 transition-colors duration-300">
    <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-16">
            <span class="inline-block px-4 py-2 rounded-full bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400 text-sm font-semibold mb-4">
                MENU ĐẶC BIỆT
            </span>
            <h2 class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-white mb-4">
                Thức uống <span class="text-amber-600 dark:text-amber-400">signature</span>
            </h2>
            <p class="text-gray-600 dark:text-gray-400 text-lg max-w-2xl mx-auto">
                Khám phá những món đồ uống đặc trưng được yêu thích nhất
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            <!-- Menu Item 1 -->
            <div class="group relative overflow-hidden rounded-3xl bg-white dark:bg-gray-800 shadow-lg hover:shadow-2xl transition-all duration-300">
                <div class="aspect-square bg-gradient-to-br from-amber-200 to-orange-300 dark:from-amber-900 dark:to-orange-900 flex items-center justify-center">
                    <span class="text-7xl group-hover:scale-110 transition-transform duration-300">☕</span>
                </div>
                <div class="p-6">
                    <div class="flex justify-between items-start mb-2">
                        <h3 class="text-lg font-bold text-gray-900 dark:text-white">Espresso</h3>
                        <span class="text-amber-600 dark:text-amber-400 font-bold">35K</span>
                    </div>
                    <p class="text-gray-500 dark:text-gray-400 text-sm">Đậm đà nguyên chất, thức tỉnh giác quan</p>
                </div>
                <div class="absolute inset-0 bg-gradient-to-t from-amber-600/90 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-6">
                    <button class="w-full py-3 rounded-xl bg-white text-amber-700 font-bold hover:bg-gray-100 transition-colors">
                        Đặt ngay
                    </button>
                </div>
            </div>

            <!-- Menu Item 2 -->
            <div class="group relative overflow-hidden rounded-3xl bg-white dark:bg-gray-800 shadow-lg hover:shadow-2xl transition-all duration-300">
                <div class="aspect-square bg-gradient-to-br from-orange-200 to-yellow-300 dark:from-orange-900 dark:to-yellow-900 flex items-center justify-center">
                    <span class="text-7xl group-hover:scale-110 transition-transform duration-300">🥛</span>
                </div>
                <div class="p-6">
                    <div class="flex justify-between items-start mb-2">
                        <h3 class="text-lg font-bold text-gray-900 dark:text-white">Cappuccino</h3>
                        <span class="text-amber-600 dark:text-amber-400 font-bold">45K</span>
                    </div>
                    <p class="text-gray-500 dark:text-gray-400 text-sm">Hòa quyện sữa béo, bọt mịn màng</p>
                </div>
                <div class="absolute inset-0 bg-gradient-to-t from-orange-600/90 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-6">
                    <button class="w-full py-3 rounded-xl bg-white text-orange-700 font-bold hover:bg-gray-100 transition-colors">
                        Đặt ngay
                    </button>
                </div>
            </div>

            <!-- Menu Item 3 -->
            <div class="group relative overflow-hidden rounded-3xl bg-white dark:bg-gray-800 shadow-lg hover:shadow-2xl transition-all duration-300">
                <div class="aspect-square bg-gradient-to-br from-yellow-200 to-amber-300 dark:from-yellow-900 dark:to-amber-900 flex items-center justify-center">
                    <span class="text-7xl group-hover:scale-110 transition-transform duration-300">🍵</span>
                </div>
                <div class="p-6">
                    <div class="flex justify-between items-start mb-2">
                        <h3 class="text-lg font-bold text-gray-900 dark:text-white">Latte</h3>
                        <span class="text-amber-600 dark:text-amber-400 font-bold">50K</span>
                    </div>
                    <p class="text-gray-500 dark:text-gray-400 text-sm">Mượt mà kem sữa, nghệ thuật latte art</p>
                </div>
                <div class="absolute inset-0 bg-gradient-to-t from-yellow-600/90 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-6">
                    <button class="w-full py-3 rounded-xl bg-white text-yellow-700 font-bold hover:bg-gray-100 transition-colors">
                        Đặt ngay
                    </button>
                </div>
            </div>

            <!-- Menu Item 4 -->
            <div class="group relative overflow-hidden rounded-3xl bg-white dark:bg-gray-800 shadow-lg hover:shadow-2xl transition-all duration-300">
                <div class="aspect-square bg-gradient-to-br from-amber-300 to-orange-400 dark:from-amber-800 dark:to-orange-800 flex items-center justify-center">
                    <span class="text-7xl group-hover:scale-110 transition-transform duration-300">🧊</span>
                </div>
                <div class="p-6">
                    <div class="flex justify-between items-start mb-2">
                        <h3 class="text-lg font-bold text-gray-900 dark:text-white">Cold Brew</h3>
                        <span class="text-amber-600 dark:text-amber-400 font-bold">55K</span>
                    </div>
                    <p class="text-gray-500 dark:text-gray-400 text-sm">Ủ lạnh 24 giờ, vị cà phê tinh tế</p>
                </div>
                <div class="absolute inset-0 bg-gradient-to-t from-amber-600/90 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-6">
                    <button class="w-full py-3 rounded-xl bg-white text-amber-700 font-bold hover:bg-gray-100 transition-colors">
                        Đặt ngay
                    </button>
                </div>
            </div>
        </div>

        <div class="text-center mt-12">
            <a href="#" class="inline-flex items-center gap-2 px-8 py-4 rounded-2xl bg-gray-900 dark:bg-white text-white dark:text-gray-900 font-bold hover:bg-gray-800 dark:hover:bg-gray-100 transform hover:-translate-y-1 transition-all duration-300 shadow-xl">
                Xem toàn bộ menu
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                </svg>
            </a>
        </div>
    </div>
</section>

<!-- Testimonials Section -->
