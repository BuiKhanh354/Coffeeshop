@{
    ViewData["Title"] = "Tài khoản của tôi";
}

@* Demo User Data *@
@{
    var userEmail = User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "user@coffeeshop.vn";
    var userName = User.Identity?.Name ?? "Khách hàng";
    var userPhone = "0987654321";
    var userAddress = "123 Nguyễn Huệ, Quận 1, TP.HCM";
}

<section class="pt-24 pb-16 min-h-screen bg-gradient-to-b from-amber-50 to-white dark:from-gray-900 dark:to-gray-800">
    <div class="max-w-6xl mx-auto px-6">
        <!-- Header -->
        <div class="text-center mb-8">
            <span class="inline-block px-4 py-2 rounded-full bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400 text-sm font-semibold mb-4">
                TÀI KHOẢN
            </span>
            <h1 class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-white mb-4">
                Xin chào, <span class="text-amber-600 dark:text-amber-400">@userName</span>!
            </h1>
            <p class="text-gray-600 dark:text-gray-400 text-lg">
                Quản lý thông tin tài khoản và đơn hàng của bạn
            </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
            <!-- Sidebar Navigation -->
            <aside class="lg:col-span-1">
                <div class="bg-white dark:bg-gray-800 rounded-2xl p-6 shadow-lg border border-gray-100 dark:border-gray-700 sticky top-24">
                    <!-- User Avatar -->
                    <div class="text-center mb-6 pb-6 border-b border-gray-100 dark:border-gray-700">
                        <div class="relative inline-block">
                            <div id="avatarContainer" class="w-20 h-20 rounded-full bg-gradient-to-r from-amber-500 to-orange-500 flex items-center justify-center text-white text-3xl font-bold mx-auto mb-4 overflow-hidden">
                                <span id="avatarInitial">@(userName.Substring(0, 1).ToUpper())</span>
                                <img id="avatarImage" src="" alt="Avatar" class="hidden w-full h-full object-cover">
                            </div>
                            <label for="avatarInput" class="absolute bottom-3 right-0 w-7 h-7 bg-amber-600 hover:bg-amber-700 rounded-full flex items-center justify-center cursor-pointer shadow-lg transition-colors">
                                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/>
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/>
                                </svg>
                            </label>
                            <input type="file" id="avatarInput" accept="image/*" class="hidden" onchange="uploadAvatar(this)">
                        </div>
                        <h3 class="font-bold text-gray-900 dark:text-white">@userName</h3>
                        <p class="text-sm text-gray-500 dark:text-gray-400">@userEmail</p>
                    </div>
                    
                    <!-- Navigation -->
                    <nav class="space-y-2">
                        <a href="/Account/Profile" class="flex items-center gap-3 px-4 py-3 rounded-xl bg-amber-50 dark:bg-amber-900/20 text-amber-700 dark:text-amber-400 font-medium">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                            </svg>
                            Thông tin cá nhân
                        </a>
                        <a href="/Account/Orders" class="flex items-center gap-3 px-4 py-3 rounded-xl text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
                            </svg>
                            Lịch sử đơn hàng
                        </a>
                        <a href="/Account/ChangePassword" class="flex items-center gap-3 px-4 py-3 rounded-xl text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/>
                            </svg>
                            Đổi mật khẩu
                        </a>
                        <div class="pt-4 mt-4 border-t border-gray-100 dark:border-gray-700">
                            <form method="post" asp-controller="Account" asp-action="Logout">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="flex items-center gap-3 px-4 py-3 rounded-xl text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors w-full">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                                    </svg>
                                    Đăng xuất
                                </button>
                            </form>
                        </div>
                    </nav>
                </div>
            </aside>

            <!-- Main Content -->
            <div class="lg:col-span-3">
                <div class="bg-white dark:bg-gray-800 rounded-2xl p-8 shadow-lg border border-gray-100 dark:border-gray-700">
                    <div class="flex items-center justify-between mb-8">
                        <h2 class="text-2xl font-bold text-gray-900 dark:text-white">Thông tin cá nhân</h2>
                        <button onclick="enableEdit()" id="editBtn" class="px-4 py-2 rounded-xl border border-amber-600 text-amber-600 hover:bg-amber-50 dark:hover:bg-amber-900/20 font-medium transition-colors flex items-center gap-2">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                            </svg>
                            Chỉnh sửa
                        </button>
                    </div>

                    <form id="profileForm" class="space-y-6">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Họ và tên</label>
                                <input type="text" name="fullName" value="@userName" disabled
                                       class="w-full px-4 py-3 rounded-xl border border-gray-200 dark:border-gray-600 bg-gray-50 dark:bg-gray-700 text-gray-900 dark:text-white disabled:opacity-60 focus:ring-2 focus:ring-amber-500 focus:border-transparent transition-all">
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Email</label>
                                <input type="email" name="email" value="@userEmail" disabled
                                       class="w-full px-4 py-3 rounded-xl border border-gray-200 dark:border-gray-600 bg-gray-50 dark:bg-gray-700 text-gray-900 dark:text-white disabled:opacity-60 focus:ring-2 focus:ring-amber-500 focus:border-transparent transition-all">
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Số điện thoại</label>
                                <input type="tel" name="phone" value="@userPhone" disabled
                                       class="w-full px-4 py-3 rounded-xl border border-gray-200 dark:border-gray-600 bg-gray-50 dark:bg-gray-700 text-gray-900 dark:text-white disabled:opacity-60 focus:ring-2 focus:ring-amber-500 focus:border-transparent transition-all">
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Ngày tham gia</label>
                                <input type="text" value="Tháng 1, 2026" disabled
                                       class="w-full px-4 py-3 rounded-xl border border-gray-200 dark:border-gray-600 bg-gray-50 dark:bg-gray-700 text-gray-500 dark:text-gray-400 disabled:opacity-60">
                            </div>
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Địa chỉ mặc định</label>
                            <textarea name="address" rows="2" disabled
                                      class="w-full px-4 py-3 rounded-xl border border-gray-200 dark:border-gray-600 bg-gray-50 dark:bg-gray-700 text-gray-900 dark:text-white disabled:opacity-60 focus:ring-2 focus:ring-amber-500 focus:border-transparent resize-none transition-all">@userAddress</textarea>
                        </div>

                        <div id="saveButtons" class="hidden flex gap-4 pt-4">
                            <button type="button" onclick="saveProfile()" class="px-6 py-3 rounded-xl bg-gradient-to-r from-amber-600 to-orange-600 text-white font-semibold hover:from-amber-700 hover:to-orange-700 transition-all shadow-lg shadow-amber-500/25">
                                Lưu thay đổi
                            </button>
                            <button type="button" onclick="cancelEdit()" class="px-6 py-3 rounded-xl border border-gray-200 dark:border-gray-600 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">
                                Hủy
                            </button>
                        </div>
                    </form>
                </div>

                <!-- Quick Stats -->
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mt-6">
                    <div class="bg-white dark:bg-gray-800 rounded-2xl p-6 shadow-lg border border-gray-100 dark:border-gray-700 text-center">
                        <div class="w-12 h-12 rounded-full bg-amber-100 dark:bg-amber-900/30 flex items-center justify-center mx-auto mb-3">
                            <svg class="w-6 h-6 text-amber-600 dark:text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
                            </svg>
                        </div>
                        <p class="text-2xl font-bold text-gray-900 dark:text-white">5</p>
                        <p class="text-sm text-gray-500 dark:text-gray-400">Đơn hàng</p>
                    </div>
                    <div class="bg-white dark:bg-gray-800 rounded-2xl p-6 shadow-lg border border-gray-100 dark:border-gray-700 text-center">
                        <div class="w-12 h-12 rounded-full bg-green-100 dark:bg-green-900/30 flex items-center justify-center mx-auto mb-3">
                            <svg class="w-6 h-6 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                            </svg>
                        </div>
                        <p class="text-2xl font-bold text-gray-900 dark:text-white">4</p>
                        <p class="text-sm text-gray-500 dark:text-gray-400">Hoàn thành</p>
                    </div>
                    <div class="bg-white dark:bg-gray-800 rounded-2xl p-6 shadow-lg border border-gray-100 dark:border-gray-700 text-center">
                        <div class="w-12 h-12 rounded-full bg-blue-100 dark:bg-blue-900/30 flex items-center justify-center mx-auto mb-3">
                            <svg class="w-6 h-6 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                            </svg>
                        </div>
                        <p class="text-2xl font-bold text-gray-900 dark:text-white">1.250.000đ</p>
                        <p class="text-sm text-gray-500 dark:text-gray-400">Tổng chi tiêu</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        // Load avatar on page load
        document.addEventListener('DOMContentLoaded', loadAvatar);

        function loadAvatar() {
            fetch('/Account/GetAvatar')
                .then(response => response.json())
                .then(data => {
                    if (data.avatarUrl) {
                        showAvatarImage(data.avatarUrl);
                    }
                })
                .catch(error => console.error('Error loading avatar:', error));
        }

        function showAvatarImage(url) {
            const avatarImage = document.getElementById('avatarImage');
            const avatarInitial = document.getElementById('avatarInitial');
            avatarImage.src = url;
            avatarImage.classList.remove('hidden');
            avatarInitial.classList.add('hidden');
        }

        function uploadAvatar(input) {
            if (!input.files || !input.files[0]) return;

            const file = input.files[0];
            const formData = new FormData();
            formData.append('avatar', file);

            // Get anti-forgery token
            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
            
            fetch('/Account/UploadAvatar', {
                method: 'POST',
                headers: {
                    'RequestVerificationToken': token || ''
                },
                body: formData
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    showAvatarImage(data.avatarUrl);
                    showToast('Đã cập nhật ảnh đại diện!');
                } else {
                    showToast(data.message || 'Có lỗi xảy ra', 'error');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                showToast('Có lỗi xảy ra khi tải ảnh', 'error');
            });
        }

        function showToast(message, type = 'success') {
            const toast = document.createElement('div');
            toast.className = `fixed bottom-6 right-6 px-6 py-3 rounded-xl shadow-lg z-50 ${type === 'success' ? 'bg-green-600' : 'bg-red-600'} text-white`;
            toast.textContent = message;
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 3000);
        }

        function enableEdit() {
            const form = document.getElementById('profileForm');
            const inputs = form.querySelectorAll('input:not([type="text"][disabled][value="Tháng 1, 2026"]), textarea');
            inputs.forEach(input => {
                if (!input.value.includes('Tháng')) {
                    input.disabled = false;
                }
            });
            document.getElementById('editBtn').classList.add('hidden');
            document.getElementById('saveButtons').classList.remove('hidden');
        }
        
        function cancelEdit() {
            const form = document.getElementById('profileForm');
            const inputs = form.querySelectorAll('input, textarea');
            inputs.forEach(input => input.disabled = true);
            document.getElementById('editBtn').classList.remove('hidden');
            document.getElementById('saveButtons').classList.add('hidden');
        }
        
        function saveProfile() {
            // Demo save
            alert('Đã lưu thông tin thành công! (Demo)');
            cancelEdit();
        }
    </script>
}
