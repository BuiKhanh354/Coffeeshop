@model CoffeeShop.Web.Models.LoginViewModel
@{
    ViewData["Title"] = "Đăng Nhập Quản Trị";
    Layout = "_AuthLayout";
}

<div class="w-full max-w-md">
    <div class="bg-white dark:bg-gray-800 rounded-3xl p-8 shadow-2xl border border-gray-100 dark:border-gray-700 relative overflow-hidden">
        <!-- Admin Badge -->
        <div class="absolute top-0 right-0 bg-gradient-to-l from-indigo-600 to-purple-600 text-white text-xs font-bold px-4 py-1 rounded-bl-xl">
            ADMIN
        </div>

        <!-- Header -->
        <div class="text-center mb-8">
            <div class="w-20 h-20 mx-auto mb-4 rounded-2xl bg-gradient-to-br from-indigo-600 to-purple-600 flex items-center justify-center shadow-lg shadow-indigo-500/30">
                <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                </svg>
            </div>
            <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">Quản Trị Viên</h1>
            <p class="text-gray-600 dark:text-gray-400">Đăng nhập vào hệ thống quản trị</p>
        </div>

        <!-- Validation Summary -->
        <div asp-validation-summary="ModelOnly" class="mb-4 p-4 bg-red-50 dark:bg-red-900/20 text-red-600 dark:text-red-400 rounded-xl text-sm"></div>

        <form method="post" asp-action="AdminLogin">
            <input type="hidden" asp-for="ReturnUrl" />
            
            <!-- Email -->
            <div class="mb-5">
                <label asp-for="Email" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Email Quản Trị</label>
                <div class="relative">
                    <input asp-for="Email" type="email" 
                           class="w-full px-4 py-3 pl-11 rounded-xl border border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-all"
                           placeholder="admin@coffeeshop.vn">
                    <svg class="w-5 h-5 text-gray-400 absolute left-3.5 top-1/2 -translate-y-1/2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                    </svg>
                </div>
                <span asp-validation-for="Email" class="text-red-500 text-sm mt-1"></span>
            </div>

            <!-- Password -->
            <div class="mb-5">
                <label asp-for="Password" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Mật khẩu</label>
                <div class="relative">
                    <input asp-for="Password" type="password" 
                           class="w-full px-4 py-3 pl-11 rounded-xl border border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-all"
                           placeholder="••••••••">
                    <svg class="w-5 h-5 text-gray-400 absolute left-3.5 top-1/2 -translate-y-1/2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
                    </svg>
                </div>
                <span asp-validation-for="Password" class="text-red-500 text-sm mt-1"></span>
            </div>

            <!-- Remember Me -->
            <div class="flex items-center justify-between mb-6">
                <label class="flex items-center gap-2 cursor-pointer">
                    <input asp-for="RememberMe" type="checkbox" class="w-4 h-4 text-indigo-600 rounded focus:ring-indigo-500">
                    <span class="text-sm text-gray-600 dark:text-gray-400">Ghi nhớ đăng nhập</span>
                </label>
            </div>

            <!-- Submit Button -->
            <button type="submit" 
                    class="w-full py-4 rounded-xl bg-gradient-to-r from-indigo-600 to-purple-600 text-white font-bold text-lg hover:from-indigo-700 hover:to-purple-700 transform hover:-translate-y-1 transition-all duration-300 shadow-lg shadow-indigo-500/25 flex items-center justify-center gap-2">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"/>
                </svg>
                Đăng nhập Quản trị
            </button>
        </form>

        <!-- Security Notice -->
        <div class="mt-6 p-4 bg-indigo-50 dark:bg-indigo-900/20 rounded-xl border border-indigo-100 dark:border-indigo-800">
            <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-indigo-600 dark:text-indigo-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <div class="text-sm text-indigo-700 dark:text-indigo-300">
                    <p class="font-medium mb-1">Lưu ý bảo mật</p>
                    <p class="text-indigo-600 dark:text-indigo-400 text-xs">Trang này chỉ dành cho quản trị viên. Mọi hoạt động đăng nhập đều được ghi lại.</p>
                </div>
            </div>
        </div>

        <!-- Demo Account -->
        <!-- <div class="mt-6 pt-6 border-t border-gray-200 dark:border-gray-700">
            <p class="text-center text-sm text-gray-500 dark:text-gray-400 mb-3">Tài khoản demo:</p>
            <div class="p-3 bg-gray-50 dark:bg-gray-700 rounded-lg text-center">
                <code class="text-indigo-600 dark:text-indigo-400 text-sm">admin@coffeeshop.vn / Admin@123</code>
            </div>
        </div> -->

        <!-- Back to User Login -->
        <p class="text-center mt-6 text-gray-600 dark:text-gray-400 text-sm">
            Bạn là khách hàng? 
            <a asp-action="Login" class="text-indigo-600 dark:text-indigo-400 font-semibold hover:underline">Đăng nhập tại đây</a>
        </p>
    </div>
</div>
