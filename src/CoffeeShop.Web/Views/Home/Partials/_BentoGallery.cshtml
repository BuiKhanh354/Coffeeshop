<!-- Bento Gallery Section -->
<section class="py-24 bg-gray-50 dark:bg-gray-800 transition-colors duration-300">
    <div class="max-w-7xl mx-auto px-6">
        <!-- Section Header -->
        <div class="text-center mb-12">
            <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-gradient-to-r from-pink-100 to-purple-100 dark:from-pink-900/30 dark:to-purple-900/30 text-pink-700 dark:text-pink-400 text-sm font-semibold uppercase tracking-wider mb-4">
                📸 Gallery
            </span>
            <h2 class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-white mb-4">
                Khoảnh Khắc <span class="text-pink-600 dark:text-pink-400">Đẹp</span>
            </h2>
            <p class="text-gray-600 dark:text-gray-400 text-lg max-w-2xl mx-auto">
                Những hình ảnh tuyệt đẹp từ Coffee Shop
            </p>
        </div>

        <!-- Bento Grid -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 auto-rows-[200px] md:auto-rows-[250px]">
            <!-- Large item - spans 2 cols and 2 rows -->
            <div class="col-span-2 row-span-2 relative group overflow-hidden rounded-3xl cursor-pointer">
                <img src="/images/about-img.png" alt="Coffee Shop" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                <div class="absolute bottom-0 left-0 right-0 p-6 translate-y-full group-hover:translate-y-0 transition-transform duration-300">
                    <h3 class="text-white text-xl font-bold mb-2">Không Gian Coffee Shop</h3>
                    <p class="text-gray-200 text-sm">Nơi hội tụ những tín đồ cà phê</p>
                </div>
            </div>

            <!-- Regular items -->
            <div class="relative group overflow-hidden rounded-3xl cursor-pointer">
                <img src="/images/Hot_Americano.png" alt="Hot Americano" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-4">
                    <span class="text-white font-semibold">Hot Americano</span>
                </div>
            </div>

            <div class="relative group overflow-hidden rounded-3xl cursor-pointer">
                <img src="/images/Floaty_Matcha_Latte.png" alt="Matcha Latte" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-4">
                    <span class="text-white font-semibold">Matcha Latte</span>
                </div>
            </div>

            <div class="relative group overflow-hidden rounded-3xl cursor-pointer">
                <img src="/images/MousseTiramisu.png" alt="Tiramisu" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-4">
                    <span class="text-white font-semibold">Mousse Tiramisu</span>
                </div>
            </div>

            <div class="relative group overflow-hidden rounded-3xl cursor-pointer">
                <img src="/images/Croissant_with_Salted_Egg.png" alt="Croissant Trứng Muối" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-4">
                    <span class="text-white font-semibold">Croissant Trứng Muối</span>
                </div>
            </div>

            <!-- Wide item - spans 2 cols -->
            <div class="col-span-2 relative group overflow-hidden rounded-3xl cursor-pointer">
                <img src="/images/teaplantation.jpg" alt="Đồi Trà" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                <div class="absolute bottom-0 left-0 right-0 p-6 translate-y-full group-hover:translate-y-0 transition-transform duration-300">
                    <h3 class="text-white text-xl font-bold mb-2">Đồi Trà Xanh Mướt</h3>
                    <p class="text-gray-200 text-sm">Nguồn nguyên liệu trà hảo hạng</p>
                </div>
            </div>

            <!-- More items -->
            <div class="relative group overflow-hidden rounded-3xl cursor-pointer">
                <img src="/images/Ice_Cappuccino.png" alt="Ice Cappuccino" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-4">
                    <span class="text-white font-semibold">Ice Cappuccino</span>
                </div>
            </div>

            <div class="relative group overflow-hidden rounded-3xl cursor-pointer">
                <img src="/images/Mochi.png" alt="Mochi" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-4">
                    <span class="text-white font-semibold">Mochi Đặc Biệt</span>
                </div>
            </div>

            <div class="relative group overflow-hidden rounded-3xl cursor-pointer">
                <img src="/images/A-Me_Mo.png" alt="A-Mê Mơ" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-4">
                    <span class="text-white font-semibold">A-Mê Mơ</span>
                </div>
            </div>

            <div class="relative group overflow-hidden rounded-3xl cursor-pointer">
                <img src="/images/Pizza_Pepperoni.png" alt="Pizza Pepperoni" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-4">
                    <span class="text-white font-semibold">Pizza Pepperoni</span>
                </div>
            </div>
        </div>
    </div>
</section>
