@{
    ViewData["Title"] = "Home";
}

<section class="bg-gray-100 dark:bg-gray-800 min-h-screen py-20">
    <div class="max-w-5xl mx-auto text-center px-6">
        <h2 class="text-5xl font-extrabold text-gray-900 dark:text-white mb-6">
            Thưởng thức cà phê đúng vị ☕
        </h2>

        <p class="text-lg text-gray-600 dark:text-gray-300 mb-10">
            Cà phê rang xay nguyên chất – không gian ấm cúng – phục vụ tận tâm
        </p>

        <div class="flex justify-center gap-6">
            <a href="#"
               class="px-6 py-3 rounded-lg bg-amber-700 text-white
                      hover:bg-amber-800 transition">
                Xem Menu
            </a>

            <a href="#"
               class="px-6 py-3 rounded-lg border border-amber-700
                      text-amber-700 dark:text-amber-400
                      hover:bg-amber-700 hover:text-white transition">
                Liên hệ
            </a>
        </div>
    </div>
</section>
