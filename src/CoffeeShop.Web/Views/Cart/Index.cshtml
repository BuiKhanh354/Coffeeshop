@model List<CoffeeShop.Web.Models.CartItem>
@{
    ViewData["Title"] = "Giỏ Hàng";
}

<!-- Cart Page -->
<section class="pt-24 pb-16 min-h-screen bg-gradient-to-b from-amber-50 to-white dark:from-gray-900 dark:to-gray-800">
    <div class="max-w-7xl mx-auto px-6">
        <!-- Header -->
        <div class="text-center mb-12">
            <span class="inline-block px-4 py-2 rounded-full bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400 text-sm font-semibold mb-4">
                GIỎ HÀNG
            </span>
            <h1 class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-white mb-4">
                Giỏ hàng <span class="text-amber-600 dark:text-amber-400">của bạn</span>
            </h1>
        </div>

        @if (Model.Count == 0)
        {
            <div class="text-center py-16">
                <div class="w-24 h-24 mx-auto mb-6 rounded-full bg-gray-100 dark:bg-gray-800 flex items-center justify-center">
                    <svg class="w-12 h-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
                    </svg>
                </div>
                <h3 class="text-2xl font-bold text-gray-700 dark:text-gray-300 mb-3">Giỏ hàng trống</h3>
                <p class="text-gray-500 dark:text-gray-400 mb-8">Bạn chưa có sản phẩm nào trong giỏ hàng</p>
                <a href="/Products" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl bg-gradient-to-r from-amber-600 to-orange-600 text-white font-bold hover:from-amber-700 hover:to-orange-700 transition-all duration-300 shadow-lg shadow-amber-500/25">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
                    </svg>
                    Tiếp tục mua sắm
                </a>
            </div>
        }
        else
        {
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                <!-- Cart Items -->
                <div class="lg:col-span-2 space-y-4" id="cartItems">
                    @foreach (var item in Model)
                    {
                        <div class="bg-white dark:bg-gray-800 rounded-2xl p-6 shadow-lg border border-gray-100 dark:border-gray-700 flex flex-col sm:flex-row gap-6" id="item-@item.ProductId">
                            <!-- Product Image -->
                            <div class="w-24 h-24 flex-shrink-0 bg-gradient-to-br from-amber-100 to-orange-100 dark:from-amber-900/20 dark:to-orange-900/20 rounded-xl flex items-center justify-center">
                                <span class="text-4xl">☕</span>
                            </div>

                            <!-- Product Info -->
                            <div class="flex-1">
                                <div class="flex justify-between items-start mb-2">
                                    <h3 class="text-lg font-bold text-gray-900 dark:text-white">@item.ProductName</h3>
                                    <button onclick="removeItem(@item.ProductId)" class="p-2 rounded-lg hover:bg-red-100 dark:hover:bg-red-900/30 text-gray-400 hover:text-red-500 transition-colors">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                        </svg>
                                    </button>
                                </div>
                                <p class="text-amber-600 dark:text-amber-400 font-semibold mb-4">@item.UnitPrice.ToString("N0")đ</p>
                                
                                <div class="flex justify-between items-center">
                                    <!-- Quantity -->
                                    <div class="flex items-center gap-0 bg-gray-100 dark:bg-gray-700 rounded-lg overflow-hidden">
                                        <button onclick="updateQuantity(@item.ProductId, @(item.Quantity - 1))" class="w-10 h-10 flex items-center justify-center hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors text-lg font-bold text-gray-700 dark:text-gray-300">−</button>
                                        <span class="w-12 h-10 flex items-center justify-center text-gray-900 dark:text-white font-bold" id="qty-@item.ProductId">@item.Quantity</span>
                                        <button onclick="updateQuantity(@item.ProductId, @(item.Quantity + 1))" class="w-10 h-10 flex items-center justify-center hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors text-lg font-bold text-gray-700 dark:text-gray-300">+</button>
                                    </div>
                                    
                                    <!-- Total -->
                                    <span class="text-xl font-bold text-gray-900 dark:text-white" id="total-@item.ProductId">
                                        @item.TotalPrice.ToString("N0")đ
                                    </span>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <!-- Order Summary -->
                <div class="lg:col-span-1">
                    <div class="bg-white dark:bg-gray-800 rounded-2xl p-6 shadow-lg border border-gray-100 dark:border-gray-700 sticky top-24">
                        <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-6">Tóm tắt đơn hàng</h3>
                        
                        <div class="space-y-4 mb-6">
                            <div class="flex justify-between text-gray-600 dark:text-gray-400">
                                <span>Tạm tính</span>
                                <span id="subTotal">@(((decimal)ViewBag.SubTotal).ToString("N0"))đ</span>
                            </div>
                            <div class="flex justify-between text-gray-600 dark:text-gray-400">
                                <span>Phí vận chuyển</span>
                                <span id="shippingFee">@(((decimal)ViewBag.ShippingFee).ToString("N0"))đ</span>
                            </div>
                            <div class="pt-4 border-t border-gray-200 dark:border-gray-700">
                                <div class="flex justify-between text-xl font-bold text-gray-900 dark:text-white">
                                    <span>Tổng cộng</span>
                                    <span class="text-amber-600 dark:text-amber-400" id="grandTotal">@(((decimal)ViewBag.Total).ToString("N0"))đ</span>
                                </div>
                            </div>
                        </div>

                        <a href="/Checkout" class="block w-full py-4 rounded-xl bg-gradient-to-r from-amber-600 to-orange-600 text-white text-center font-bold text-lg hover:from-amber-700 hover:to-orange-700 transition-all duration-300 shadow-lg shadow-amber-500/25 mb-4">
                            Tiến hành thanh toán
                        </a>

                        <a href="/Products" class="block w-full py-4 rounded-xl border-2 border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 text-center font-semibold hover:border-amber-600 hover:text-amber-600 dark:hover:border-amber-400 dark:hover:text-amber-400 transition-all duration-300">
                            Tiếp tục mua sắm
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</section>

@section Scripts {
<script>
    function updateQuantity(productId, quantity) {
        if (quantity < 1) {
            removeItem(productId);
            return;
        }

        fetch('/Cart/UpdateQuantity', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: `productId=${productId}&quantity=${quantity}`
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                document.getElementById(`qty-${productId}`).textContent = quantity;
                document.getElementById('subTotal').textContent = formatNumber(data.subTotal) + 'đ';
                document.getElementById('grandTotal').textContent = formatNumber(data.total) + 'đ';
                updateCartCount(data.cartCount);
                
                // Reload to update item totals
                location.reload();
            }
        })
        .catch(error => console.error('Error:', error));
    }

    function removeItem(productId) {
        fetch('/Cart/Remove', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: `productId=${productId}`
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                const item = document.getElementById(`item-${productId}`);
                item.style.opacity = '0';
                item.style.transform = 'translateX(-20px)';
                setTimeout(() => {
                    location.reload();
                }, 300);
            }
        })
        .catch(error => console.error('Error:', error));
    }

    function formatNumber(num) {
        return num.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ",");
    }

    function updateCartCount(count) {
        const cartBadge = document.getElementById('cartBadge');
        if (cartBadge) {
            if (count > 0) {
                cartBadge.textContent = count;
                cartBadge.classList.remove('hidden');
            } else {
                cartBadge.classList.add('hidden');
            }
        }
    }
</script>
}
